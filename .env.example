# SearXNG 环境变量配置
# 用于 docker compose 部署

# ============================================
# 基础配置
# ============================================
# SearXNG 绑定的内部端口 (无需修改)
SEARXNG_PORT=8080

# Nginx 暴露的外部端口
# HTTP 模式
HTTP_PORT=9080
# HTTPS 模式
HTTPS_PORT=9443

# 域名或IP地址 (用于生成 settings.yml 中的 server.base_url 和 HTTPS 证书)
DOMAIN=localhost

# SearXNG 基础 URL (用于生成正确的重定向链接)
SEARXNG_BASE_URL=http://localhost:9080

# ============================================
# MCP Server 配置 (可选, 一般无需修改)
# ============================================
# MCP 服务监听的内部地址/端口, 仅 docker network 内访问
# 对外通过 Nginx 暴露在 ${HTTP_PORT} 或 ${HTTPS_PORT} 的 /mcp 路径
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ============================================
# 出站代理 (访问外网搜索引擎, 如 Google/Bing)
# ============================================
# 若 SearXNG 容器无法直连外网 (例如内网/被墙环境), 设置此变量后
# setup.sh 会自动把代理写入 searxng/settings.yml 的 outgoing.proxies 字段
#
# 留空                 = 不使用代理 (直连)
# http://host:port     = HTTP 代理
# socks5h://host:port  = SOCKS5 代理 (DNS 也走代理, 推荐)
#
# 注意: 代理地址需在 docker network 中可达
#   - 宿主机上的代理  → http://host.docker.internal:port
#     (docker-compose.yml 已配置 extra_hosts: host.docker.internal→host-gateway)
#   - 局域网代理      → http://<lan-ip>:port (例如 http://192.168.137.1:10808)
#   - 同 docker 网络代理 → http://<service-name>:port
OUTGOING_PROXY=

# ============================================
# Basic Auth 配置
# ============================================
# 用户名
AUTH_USER=admin

# 密码 (明文，setup.sh 脚本会通过 httpd:alpine 容器使用 htpasswd 加密为 bcrypt)
AUTH_PASSWORD=admin123

# ============================================
# HTTPS / TLS 证书配置 (docker-compose.https.yml)
# ============================================
# 证书存放路径 (相对于项目根目录)
CERT_PATH=./certs

# 如果使用 Let's Encrypt (certbot)，设置邮箱
LETSENCRYPT_EMAIL=admin@example.com
